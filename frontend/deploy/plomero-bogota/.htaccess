# =================================================
# .htaccess para Angular SSG (prerender) en /plomero-bogota/
# Ubicar en: /public_html/plomero-bogota/.htaccess
# =================================================

# Evitar que Apache agregue trailing slash (301) a directorios
# Las sub-rutas prerenderizadas se sirven internamente sin redirect
DirectorySlash Off

# Habilitar mod_rewrite
RewriteEngine On

# NOTA: NO forzar HTTPS aquí.
# El .htaccess raíz de WordPress/LiteSpeed ya maneja HTTPS a nivel dominio.
# Duplicarlo aquí causa redirect loop porque LiteSpeed proxy
# siempre reporta HTTPS=off al backend.

# Proteger archivos SEO críticos — servir tal cual, NUNCA reescribir
RewriteRule ^robots\.txt$ - [L]
RewriteRule ^sitemap\.xml$ - [L]

# Forzar Content-Type correcto para robots.txt
<Files "robots.txt">
  ForceType text/plain
</Files>
<Files "sitemap.xml">
  ForceType application/xml
</Files>

# Archivos existentes → servir directamente
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Directorios prerenderizados → servir su index.html SIN redirect 301
# /servicios → sirve internamente servicios/index.html (sin 301 a /servicios/)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

# SPA Fallback: solo si no hay archivo ni directorio prerenderizado
RewriteRule ^ index.html [L]

# ---- Compresión GZIP ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ---- Cabeceras de caché ----
<IfModule mod_expires.c>
  ExpiresActive On

  # JS y CSS con hash en nombre → caché agresivo (1 año)
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"

  # Fuentes → 1 año
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # Imágenes → 1 mes
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"

  # HTML → no cachear (cada deploy actualiza)
  ExpiresByType text/html "access plus 0 seconds"

  # XML (sitemap) → 1 día
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
</IfModule>

# Cache-Control para archivos con hash (inmutables)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  <FilesMatch "\.(webp|png|jpg|jpeg|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.(woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ---- Seguridad ----
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Bloquear acceso a archivos ocultos
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
