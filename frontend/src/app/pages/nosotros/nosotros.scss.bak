// ══════════════════════════════════════════════════════════
//  NOSOTROS – Premium Dark Landing
// ══════════════════════════════════════════════════════════

$color-primary: #0d1b2e;
$color-blue: #2b6cb0;
$color-blue-light: #4299e1;
$color-orange: #ed8936;
$color-orange-light: #f6ad55;
$color-orange-dark: #dd6b20;

// ── Page Header ────────────────────────────────
.page-header--nosotros {
  background: linear-gradient(160deg, #0d1b2e 0%, #1a365d 60%, #2b6cb0 100%);
  padding: 6rem 1rem 5rem;
  position: relative;
  overflow: hidden;
  text-align: center;

  &::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 80% 20%, rgba($color-orange, 0.08) 0%, transparent 70%),
      radial-gradient(ellipse 50% 70% at 20% 80%, rgba($color-blue, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  &::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .container {
    position: relative;
    z-index: 2;
  }

  h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    position: relative;
    display: inline-block;
    line-height: 1.2;
  }

  p {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.6;
  }
}

.page-header__underline {
  position: absolute;
  bottom: -6px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 3px;
  background: linear-gradient(90deg, $color-orange-light, $color-orange, $color-orange-dark);
  border-radius: 2px;
  animation: underline-expand 1.2s 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes underline-expand {
  to { width: 80%; }
}

.page-header__particles {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.page-header__particle {
  position: absolute;
  border-radius: 50%;
  opacity: 0;
  animation: particle-float 8s ease-in-out infinite;

  &:nth-child(1) {
    width: 6px; height: 6px;
    background: rgba($color-orange-light, 0.4);
    top: 20%; left: 15%;
    animation-delay: 0s;
  }
  &:nth-child(2) {
    width: 8px; height: 8px;
    background: rgba($color-orange, 0.3);
    top: 60%; right: 20%;
    animation-delay: 2s;
  }
  &:nth-child(3) {
    width: 4px; height: 4px;
    background: rgba(255,255,255,0.25);
    top: 30%; right: 30%;
    animation-delay: 4s;
  }
  &:nth-child(4) {
    width: 10px; height: 10px;
    background: rgba($color-blue, 0.2);
    bottom: 20%; left: 25%;
    animation-delay: 1s;
  }
}

@keyframes particle-float {
  0%, 100% { opacity: 0; transform: translateY(0) scale(1); }
  20% { opacity: 1; }
  80% { opacity: 1; }
  50% { transform: translateY(-30px) scale(1.3); }
}

// ── Intro / Quiénes Somos ──────────────────────
.about-intro {
  padding: 5rem 1rem 4rem;
  background: linear-gradient(180deg, #f8fafc 0%, #fff 100%);

  &__content {
    max-width: 740px;
    margin: 0 auto;
    text-align: center;
  }

  &__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.3rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba($color-orange, 0.08);
    color: $color-orange-dark;
    border: 1px solid rgba($color-orange, 0.15);
    margin-bottom: 1.75rem;

    svg { color: $color-orange; flex-shrink: 0; }
  }

  h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: $color-primary;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #4a5568;
    margin-bottom: 0.75rem;
  }
}

// ── Misión y Visión ────────────────────────────
.about-mv {
  padding: 5rem 1rem;
  background: linear-gradient(180deg, $color-primary 0%, #132a4a 100%);
  position: relative;
  overflow: hidden;

  &__glow {
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba($color-orange, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  &__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  &__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.5s ease,
      border-color 0.4s ease;

    &:hover {
      transform: translateY(-6px);
      border-color: rgba($color-orange, 0.2);
      box-shadow:
        0 20px 50px rgba(0, 0, 0, 0.3),
        0 0 40px rgba($color-orange, 0.06);
    }

    h3 {
      font-size: 1.2rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.75rem;
      letter-spacing: -0.01em;
    }

    p {
      font-size: 0.95rem;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.6);
    }
  }

  &__card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, $color-orange-light, $color-orange, transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  &__card:hover &__card-accent { opacity: 1; }

  &__card-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba($color-orange, 0.1);
    border: 1px solid rgba($color-orange, 0.15);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: $color-orange-light;
    margin-bottom: 1.25rem;
    transition: transform 0.4s ease, background 0.4s ease;
  }

  &__card:hover &__card-icon {
    transform: scale(1.08);
    background: rgba($color-orange, 0.15);
  }
}

// ── Valores (color card variants) ──────────────
$valor-blue: #2b6cb0;
$valor-orange: #ed8936;
$valor-teal: #319795;
$valor-purple: #805ad5;

.about-valores {
  padding: 6rem 1rem 5.5rem;
  background: linear-gradient(180deg, #0d1b2e 0%, #132d4f 50%, #0d1b2e 100%);
  position: relative;
  overflow: hidden;

  &__bg-shape {
    position: absolute;
    top: -120px;
    right: -100px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba($color-orange, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  &__header {
    text-align: center;
    margin-bottom: 3.5rem;
    position: relative;
    z-index: 1;
  }

  &__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 1.3rem;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba($color-orange, 0.12);
    color: $color-orange-light;
    border: 1px solid rgba($color-orange, 0.2);
    margin-bottom: 1.25rem;

    svg { flex-shrink: 0; }
  }

  h2 {
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.025em;
    position: relative;
    display: inline-block;
    line-height: 1.2;
  }

  &__title-line {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, $color-orange-light, $color-orange);
  }

  &__subtitle {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.55);
    max-width: 540px;
    margin: 1.25rem auto 0;
    line-height: 1.7;
  }

  &__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
    max-width: 1060px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  // ── Card base ──
  &__card {
    border-radius: 20px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    transition:
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.55s ease,
      border-color 0.4s ease;

    &:hover {
      transform: translateY(-8px);
      border-color: rgba(255, 255, 255, 0.15);
    }
  }

  // ── Card visual header ──
  &__card-visual {
    position: relative;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  &__card-visual-bg {
    position: absolute;
    inset: 0;
  }

  &__card-visual-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      radial-gradient(circle at 70% 60%, rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      radial-gradient(circle at 50% 80%, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 40px 40px, 60px 60px, 30px 30px;
  }

  &__card-visual-icon {
    position: relative;
    z-index: 2;
    width: 64px;
    height: 64px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.25);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  &__card:hover &__card-visual-icon {
    transform: scale(1.12) rotate(5deg);
  }

  &__card-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.12), transparent);
    transform: skewX(-20deg);
    transition: left 0.8s ease;
    z-index: 3;
    pointer-events: none;
  }

  &__card:hover &__card-shine {
    left: 150%;
  }

  // ── Card body ──
  &__card-body {
    padding: 1.5rem 1.25rem 1.75rem;
    text-align: center;

    h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    p {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.55);
      line-height: 1.6;
      margin-bottom: 0.85rem;
    }
  }

  &__card-tag {
    display: inline-block;
    padding: 0.28rem 0.8rem;
    border-radius: 50px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  // ── Color variants ──
  &__card--blue {
    .about-valores__card-visual-bg {
      background: linear-gradient(135deg, rgba($valor-blue, 0.7), rgba(#1a365d, 0.9));
    }
    &:hover {
      box-shadow: 0 20px 60px rgba($valor-blue, 0.2), 0 0 40px rgba($valor-blue, 0.08);
    }
    .about-valores__card-tag {
      background: rgba($valor-blue, 0.12);
      color: rgba(#90cdf4, 0.9);
      border-color: rgba($valor-blue, 0.2);
    }
  }

  &__card--orange {
    .about-valores__card-visual-bg {
      background: linear-gradient(135deg, rgba($valor-orange, 0.7), rgba(#c05621, 0.9));
    }
    &:hover {
      box-shadow: 0 20px 60px rgba($valor-orange, 0.2), 0 0 40px rgba($valor-orange, 0.08);
    }
    .about-valores__card-tag {
      background: rgba($valor-orange, 0.12);
      color: rgba(#fbd38d, 0.9);
      border-color: rgba($valor-orange, 0.2);
    }
  }

  &__card--teal {
    .about-valores__card-visual-bg {
      background: linear-gradient(135deg, rgba($valor-teal, 0.7), rgba(#234e52, 0.9));
    }
    &:hover {
      box-shadow: 0 20px 60px rgba($valor-teal, 0.2), 0 0 40px rgba($valor-teal, 0.08);
    }
    .about-valores__card-tag {
      background: rgba($valor-teal, 0.12);
      color: rgba(#81e6d9, 0.9);
      border-color: rgba($valor-teal, 0.2);
    }
  }

  &__card--purple {
    .about-valores__card-visual-bg {
      background: linear-gradient(135deg, rgba($valor-purple, 0.7), rgba(#44337a, 0.9));
    }
    &:hover {
      box-shadow: 0 20px 60px rgba($valor-purple, 0.2), 0 0 40px rgba($valor-purple, 0.08);
    }
    .about-valores__card-tag {
      background: rgba($valor-purple, 0.12);
      color: rgba(#d6bcfa, 0.9);
      border-color: rgba($valor-purple, 0.2);
    }
  }
}

// ── Stats / Por qué elegirnos ──────────────────
.about-stats {
  padding: 5rem 1rem;
  background: linear-gradient(165deg, $color-primary 0%, #1a365d 60%, $color-primary 100%);
  position: relative;
  overflow: hidden;

  &__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba($color-orange, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  &__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  &__item {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    padding: 2rem 1.25rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.5s ease,
      border-color 0.4s ease;

    &:hover {
      transform: translateY(-6px);
      border-color: rgba($color-orange, 0.2);
      box-shadow:
        0 20px 50px rgba(0, 0, 0, 0.3),
        0 0 30px rgba($color-orange, 0.06);
    }
  }

  &__icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba($color-orange, 0.1);
    border: 1px solid rgba($color-orange, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: $color-orange-light;
    margin-bottom: 1rem;
    transition: transform 0.4s ease;
  }

  &__item:hover &__icon {
    transform: scale(1.1);
  }

  &__title {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.3rem;
    letter-spacing: -0.01em;
  }

  &__label {
    display: block;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.4;
  }
}

// ── Equipo ─────────────────────────────────────
.about-equipo {
  padding: 6rem 1rem 5.5rem;
  background: linear-gradient(180deg, #0d1b2e 0%, #132d4f 50%, #0d1b2e 100%);
  position: relative;
  overflow: hidden;

  &__bg-particles {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 15% 25%, rgba($color-orange, 0.04) 0%, transparent 50%),
      radial-gradient(circle at 85% 75%, rgba($color-blue, 0.04) 0%, transparent 50%);
    pointer-events: none;
  }

  &__header {
    text-align: center;
    margin-bottom: 3.5rem;
    position: relative;
    z-index: 1;
  }

  &__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 1.3rem;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba($color-blue, 0.1);
    color: $color-blue-light;
    border: 1px solid rgba($color-blue, 0.2);
    margin-bottom: 1.25rem;

    svg { flex-shrink: 0; }
  }

  h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.025em;
    position: relative;
    display: inline-block;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  &__title-line {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, $color-orange-light, $color-orange);
  }

  &__subtitle {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.5);
    max-width: 520px;
    margin: 0.5rem auto 0;
    line-height: 1.6;
  }

  &__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
    max-width: 960px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  &__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    overflow: hidden;
    transition:
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.55s ease,
      border-color 0.4s ease;

    &:hover {
      transform: translateY(-8px);
      border-color: rgba($color-orange, 0.25);
      box-shadow:
        0 24px 60px rgba(0, 0, 0, 0.3),
        0 0 30px rgba($color-orange, 0.06);
    }
  }

  &__card-top {
    position: relative;
    padding: 1.75rem 1.25rem 0;
    display: flex;
    justify-content: center;
  }

  &__card-status {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #48bb78;
    box-shadow: 0 0 8px rgba(#48bb78, 0.5);

    &::after {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      border: 2px solid rgba(#48bb78, 0.2);
      animation: statusPulse 2.5s ease-in-out infinite;
    }
  }

  &__card-foto {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba($color-blue, 0.12), rgba($color-blue, 0.04));
    border: 2px solid rgba($color-blue, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: $color-blue-light;
    overflow: hidden;
    transition:
      border-color 0.4s ease,
      transform 0.4s ease;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  &__card:hover &__card-foto {
    border-color: rgba($color-orange, 0.4);
    transform: scale(1.05);
  }

  &__card-body {
    padding: 1.25rem 1.25rem 1.75rem;
    text-align: center;
  }

  &__card-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  &__card-role {
    display: block;
    font-size: 0.78rem;
    color: $color-orange-light;
    font-weight: 600;
    margin-bottom: 0.85rem;
  }

  &__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;

    span {
      padding: 0.22rem 0.65rem;
      border-radius: 50px;
      font-size: 0.65rem;
      font-weight: 600;
      background: rgba(255, 255, 255, 0.06);
      color: rgba(255, 255, 255, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.08);
      letter-spacing: 0.02em;
    }
  }

  &__note {
    text-align: center;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 2.5rem;
    position: relative;
    z-index: 1;
  }
}

@keyframes statusPulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.4); opacity: 0; }
}

// ── CTA ────────────────────────────────────────
.about-cta {
  padding: 5.5rem 1rem;
  background: linear-gradient(165deg, $color-primary 0%, #1a365d 60%, $color-primary 100%);
  position: relative;
  overflow: hidden;

  &__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba($color-orange, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  &__content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 1;

    h2 {
      font-size: clamp(1.5rem, 3.5vw, 2.2rem);
      font-weight: 800;
      color: #fff;
      margin-bottom: 0.75rem;
      letter-spacing: -0.02em;
    }

    p {
      color: rgba(255, 255, 255, 0.6);
      font-size: 1.05rem;
      margin-bottom: 2.5rem;
      line-height: 1.7;
    }
  }

  &__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  &__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2rem;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.35s ease;

    &:hover { transform: translateY(-4px); }

    &--wa {
      background: linear-gradient(135deg, #25d366, #128c48);
      color: #fff;
      box-shadow: 0 6px 24px rgba(37, 211, 102, 0.3);
      &:hover { box-shadow: 0 12px 40px rgba(37, 211, 102, 0.45); }
    }

    &--contact {
      background: rgba(255, 255, 255, 0.06);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(8px);
      &:hover {
        background: rgba(255, 255, 255, 0.1);
        box-shadow: 0 12px 40px rgba(255, 255, 255, 0.06);
      }
    }
  }
}

// ── Scroll Reveal ──────────────────────────────
[data-animate].animate-init {
  opacity: 0;
  transition:
    opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);

  &[data-animate="fade-up"] {
    transform: translateY(30px);
  }

  &.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

// ── Responsive ─────────────────────────────────
@media (max-width: 960px) {
  .about-valores__grid {
    grid-template-columns: repeat(2, 1fr);
    max-width: 560px;
  }

  .about-valores__card-visual {
    height: 100px;
  }

  .about-stats__grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .about-equipo__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .page-header--nosotros {
    padding: 4rem 1rem 3.5rem;
  }

  .about-intro {
    padding: 3.5rem 1rem 3rem;
  }

  .about-mv {
    padding: 3.5rem 1rem;
  }

  .about-mv__grid {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .about-mv__card {
    padding: 2rem 1.5rem;
  }

  .about-valores {
    padding: 4rem 1rem 3.5rem;
  }

  .about-valores__grid {
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 340px;
    margin: 0 auto;
  }

  .about-valores__card-visual {
    height: 90px;
  }

  .about-valores__card-visual-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
  }

  .about-stats {
    padding: 3.5rem 1rem;
  }

  .about-stats__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .about-stats__item {
    padding: 1.5rem 1rem;
  }

  .about-stats__title {
    font-size: 0.95rem;
  }

  .about-equipo {
    padding: 4rem 1rem 3.5rem;
  }

  .about-equipo__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .about-cta {
    padding: 4rem 1rem;
  }

  .about-cta__actions {
    flex-direction: column;
    align-items: stretch;
  }

  .about-cta__btn {
    text-align: center;
    justify-content: center;
  }
}

// ── Reduced motion ─────────────────────────────
@media (prefers-reduced-motion: reduce) {
  [data-animate].animate-init {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }

  .page-header__underline {
    animation: none;
    width: 80%;
  }

  .page-header__particle {
    animation: none !important;
    opacity: 0.5 !important;
  }
}
